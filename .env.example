# DeepSeek API Key (默认 provider)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxx

# Anthropic API Key (备选)
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (备选，含 DALL-E 文生图)
# OPENAI_API_KEY=sk-xxx

# Agnes AI API Key (视觉辅助，全模态模型)
# 获取地址: https://platform.agnes-ai.com/
# AGNES_API_KEY=ag-xxx

# Kimi K3 API Key（文本生成与多模态视觉）
# 获取地址: https://platform.kimi.ai/
# KIMI_API_KEY=sk-xxx
# 也兼容 Moonshot 官方环境变量名 MOONSHOT_API_KEY

# 本地 LLM (可选)
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
